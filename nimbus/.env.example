# These fields live as a Proton Pass item ("Nimbus", in the Agent Secrets
# vault) now, not a real .env file — see ../SETUP.md's "Secrets management"
# section. Deployed via ./scripts/pass-deploy-remote.sh, which fetches
# these and pipes them over SSH to the Pi; nothing is written to disk there
# either. This file just documents which fields that item needs.
#
#   # generate passwords/secrets with: openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 32

DB_PASSWORD=CHANGE_ME_DB_PASSWORD
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
INITIAL_ADMIN_EMAIL=you@example.com
INITIAL_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Generic OIDC — see SETUP.md's Nimbus section for how these were obtained
# from Infomaniak's IK-AUTH (or your own OIDC provider).
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
