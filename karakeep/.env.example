# These fields live as a Proton Pass item ("Karakeep", in the Agent Secrets
# vault) now, not a real .env file — see ../SETUP.md's "Secrets management"
# section. This file just documents which fields that item needs.
#
#   # generate a strong secret with: openssl rand -base64 48 | tr -dc 'A-Za-z0-9' | head -c 64

# NextAuth.js session/JWT signing secret.
NEXTAUTH_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Meilisearch's own auth key — shared between the web and meilisearch
# services (both get it as an explicit ${MEILI_MASTER_KEY} reference in
# compose.yaml now, not env_file, since there's no real .env to read).
MEILI_MASTER_KEY=CHANGE_ME_LONG_RANDOM_SECRET

# Gemini API key (https://aistudio.google.com/apikey), used via Gemini's
# OpenAI-compatible endpoint for AI auto-tagging — see compose.yaml for the
# provider config (OPENAI_BASE_URL, INFERENCE_TEXT_MODEL/INFERENCE_IMAGE_MODEL).
OPENAI_API_KEY=CHANGE_ME
