# The real accounts.conf now lives as a whole-file secret in a Proton Pass
# item ("Copyparty", field ACCOUNTS_CONF, in the Agent Secrets vault) — see
# ../../SETUP.md's "Secrets management" section. It's rendered fresh to
# this exact path before each deploy via ./scripts/pass-render-file.sh,
# since copyparty needs a real file here (unlike every other app, whose
# secrets are exported as env vars and never touch disk). This template
# just documents the expected structure.
#
#   # generate a strong password with: openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 32

[accounts]
  # username: password
  admin: CHANGE_ME_ADMIN_PASSWORD
  inbox: CHANGE_ME_INBOX_PASSWORD
