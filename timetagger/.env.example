# These fields live as a Proton Pass item ("TimeTagger", in the "Self-Hosted
# Secrets" vault) now, not a real .env file — see ../SETUP.md's "Secrets
# management" section. This file just documents which fields that item needs.

# From registering a new OIDC application in Infomaniak's IK-AUTH
# (manager.infomaniak.com > your account > Cloud/IK-AUTH). Redirect URI must
# be set EXACTLY to https://time.mathewcsims.uk/oauth2/callback — Infomaniak
# rejects the exchange otherwise. Use a separate IK-AUTH application from
# ../nimbus/'s (not the same client) so each app's OAuth grant is independent.
OIDC_CLIENT_ID=CHANGE_ME
OIDC_CLIENT_SECRET=CHANGE_ME

# oauth2-proxy's own session-cookie encryption key (not an Infomaniak value)
# — generate with scripts/pass-create-timetagger-secrets.sh, or manually:
#   python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
OAUTH2_PROXY_COOKIE_SECRET=CHANGE_ME

# The ONLY email address allowed to log in — see compose.yaml's file header
# for why this matters (login.infomaniak.com is Infomaniak's shared identity
# service across ALL its customers, not just this account).
ALLOWED_EMAIL=you@example.com
