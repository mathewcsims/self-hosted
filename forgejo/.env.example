# These fields live as fields on the existing "Forgejo" Proton Pass item
# (Self-Hosted Secrets vault) — the same item that already holds
# ADMIN_USERNAME/ADMIN_PASSWORD, not a new item. See ../SETUP.md's
# "Secrets management" section. This file just documents which fields that
# item needs; there's no real .env to copy anymore.

# SMTP — a NEW mailbox/credentials created specifically for Forgejo,
# deliberately not reused from Ghost's own SMTP setup (see ../blog/).
SMTP_HOST=CHANGE_ME
SMTP_PORT=CHANGE_ME
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
MAIL_FROM=CHANGE_ME
