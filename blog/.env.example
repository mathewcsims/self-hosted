# Copy to .env and fill in real values. .env is gitignored — never commit it.

# MySQL. Generate both with: openssl rand -base64 24 | tr -d '=+/' | cut -c1-24
DB_ROOT_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL
DB_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL

# SMTP
SMTP_HOST=CHANGE_ME
SMTP_PORT=CHANGE_ME
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
MAIL_FROM=CHANGE_ME

# Tinybird (web analytics). Copy TINYBIRD_ADMIN_TOKEN and TINYBIRD_WORKSPACE_ID
# directly from the Tinybird dashboard (Settings → Tokens / Settings →
# General) — no `tb login` needed, see SETUP.md for why. TINYBIRD_API_URL is
# the region-specific host shown on the same Settings page (e.g.
# https://api.europe-west2.gcp.tinybird.co). TINYBIRD_TRACKER_TOKEN is
# generated automatically by the tinybird-deploy step — fetch it afterward
# (see SETUP.md) and add it here, then redeploy.
TINYBIRD_API_URL=CHANGE_ME
TINYBIRD_ADMIN_TOKEN=CHANGE_ME
TINYBIRD_WORKSPACE_ID=CHANGE_ME
TINYBIRD_TRACKER_TOKEN=CHANGE_ME
