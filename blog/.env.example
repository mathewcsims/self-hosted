# Copy to .env and fill in real values. .env is gitignored — never commit it.

# MySQL. Generate both with: openssl rand -base64 24 | tr -d '=+/' | cut -c1-24
DB_ROOT_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL
DB_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL

# SMTP
SMTP_HOST=CHANGE_ME
