# Copy to .env and fill in real values. .env is gitignored — never commit it.

# JWT signing secret. A weak/default one was a real CVSS 9.1 CVE in this app
# (GHSA-hjjg-vw4j-986x) — generate a genuinely random value, never leave the
# image's own placeholder. Generate with: openssl rand -base64 32
DT_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
