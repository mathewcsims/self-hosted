# Template for pi-reverse-proxy/.env — copy this to .env (gitignored, since
# it's environment-specific, not a template) and fill in your own values.
#
#   cp .env.example .env

CP_DOMAIN=cp.example.com
ACME_EMAIL=you@example.com

# The Mac's LAN IP (run `ipconfig getifaddr en1` on the Mac). NO port, NO scheme.
# Both the Mac and the Pi should have fixed IPs via DHCP reservations.
MAC_IP=10.0.0.2

# Other hostnames (router admin, other apps) are hardcoded directly in
# Caddyfile, not env vars — see SETUP.md's Troubleshooting section for why.

# DigitalOcean API token, used by the caddy-dns/digitalocean module for the
# DNS-01 ACME challenge — needed only for wildcard certs (e.g.
# archivebox.mathewcsims.uk's per-snapshot subdomains), since Let's Encrypt
# can't validate a wildcard via the HTTP-01 challenge every other site here
# uses. Generate at DigitalOcean → Settings → API → Generate New Token,
# scoped to DNS read/write if your account supports granular scoping.
DO_API_TOKEN=CHANGE_ME
