# Global options
{
	# Let's Encrypt expiry notices. Set in ./.env
	email {$ACME_EMAIL}

	# caddy-ratelimit (see Dockerfile) isn't in Caddy's default directive
	# order, so it must be told where to run. "first" = every site block
	# checks its rate-limit zones before anything else (headers, rewrites,
	# proxying) — an over-limit request is rejected as cheaply as possible,
	# and never reaches copyparty/Memos/Vikunja/Nimbus at all.
	order rate_limit first
}

# Reusable hardening headers — HSTS (force HTTPS on repeat visits),
# clickjacking and MIME-sniffing protection, conservative referrer leakage.
# Was Vikunja-only ("wasn't asked for elsewhere"); now applied everywhere
# per "harden Copyparty/Nimbus/Caddy in general" — it's free and every app
# here is either private or has an admin login worth protecting.
(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

# General-purpose per-site, per-IP request budget — coarse abuse/DoS
# protection, not a substitute for each app's own auth-specific limits
# (copyparty has --ban-pw/--ban-403 built in and enabled by default; Vikunja
# has VIKUNJA_RATELIMIT_*; Nimbus has none at all, see the @auth zone below).
# 300 req/min/IP is loose enough not to bother a real browsing session
# (page + assets + polling) while still capping a single source's blast
# radius. Zone name is parameterized per site (import ... <name>) so each
# site gets its own independent budget rather than sharing one global bucket.
(general_ratelimit) {
	rate_limit {
		zone rl_{args[0]} {
			key {remote_host}
			events 300
			window 1m
		}
	}
}

# ── copyparty (running on the Mac) ───────────────────────────────────────
# Clean public URL https://cp.mathewcsims.uk. Caddy gets the cert here (it
# owns 80/443) and proxies to plain-HTTP copyparty on the Mac. Caddy preserves
# the Host header and adds X-Forwarded-Proto=https, so copyparty generates
# correct https links and logs real client IPs (it trusts the Pi's private
# LAN IP by default).
{$CP_DOMAIN} {
	import security_headers
	import general_ratelimit cp
	reverse_proxy http://{$MAC_IP}:3923
}

# ── Memos (running on the Mac) ────────────────────────────────────────────
# Clean public URL https://prospect-ukri-tus.mathewcsims.uk. Same pattern as
# copyparty above: Caddy terminates TLS and proxies to plain-HTTP Memos on the
# Mac. Caddy's reverse_proxy sets X-Forwarded-For/-Proto/-Host by default —
# that, plus MEMOS_INSTANCE_URL set in the Mac's compose.yaml, is everything
# Memos needs to build correct URLs, including OAuth callback URLs, once SSO
# is configured in its admin UI. Nothing here needs to change for OAuth setup.
# The DOMAIN below is hardcoded (see the mc37 note): as a site block's key, an
# unset/empty env var there would produce a keyless "{ }" block that crashes
# Caddy on startup. $MAC_IP doesn't have that failure mode — it's only used as
# a value inside reverse_proxy, and it's already wired into compose.yaml's
# environment: block and proven working by the copyparty block above — so it's
# used here instead of a second hardcoded IP, for a single source of truth if
# the Mac's LAN IP ever changes.
prospect-ukri-tus.mathewcsims.uk {
	import security_headers
	import general_ratelimit memos

	# Memos has no rate-limiting, brute-force lockout, or CAPTCHA of its own
	# anywhere in its source (confirmed by reading it) — same gap class as
	# Nimbus. Registration is deliberately open here (this is for Prospect
	# members to self-signup), so unlike Nimbus this can't just be "strict
	# zone on all of /api/v1/auth/*" — a genuine new member still needs to
	# be able to sign up without hassle. Two separate, purpose-matched zones:
	rate_limit {
		# Credential-stuffing against existing accounts: sign-in and token
		# refresh. 20/min/IP is well above any real user's need but caps
		# automated password-guessing.
		zone rl_memos_auth {
			match {
				path /api/v1/auth/signin /api/v1/auth/refresh
			}
			key {remote_host}
			events 20
			window 1m
		}
		# Registration spam/bot floods: POST /api/v1/users is the signup
		# endpoint (also used for admin user-management, but only unauthed
		# POST is what an anonymous signup bot can hit). 5/min/IP is
		# generous for a real one-off signup, tight against scripted abuse.
		zone rl_memos_register {
			match {
				method POST
				path /api/v1/users
			}
			key {remote_host}
			events 5
			window 1m
		}
	}

	reverse_proxy http://{$MAC_IP}:5230
}

# ── Vikunja (running on the Mac) ───────────────────────────────────────────
# Clean public URL https://vikunja.mathewcsims.uk. Same pattern as copyparty
# above. Vikunja's own image is pinned to an exact patched version and
# hardened at the app level (no self-registration, rate limiting on, link
# sharing off, trusted-proxy config so it can tell real clients from the
# podman gateway) — see vikunja/compose.yaml for the reasoning.
vikunja.mathewcsims.uk {
	import security_headers
	import general_ratelimit vikunja
	reverse_proxy http://{$MAC_IP}:3456
}

# ── Ghost blog (running on the Mac) ───────────────────────────────────────
# Clean public URL https://blog.mathewcsims.uk — replaces paid Ghost(Pro)
# hosting. Same pattern as Vikunja above. Ghost's own docs warn that without
# X-Forwarded-Proto being set correctly behind a TLS-terminating proxy, it
# creates an infinite HTTPS redirect loop — Caddy's reverse_proxy sets this
# by default, so nothing extra is needed here for that specifically.
blog.mathewcsims.uk {
	import security_headers
	import general_ratelimit blog

	# Ghost has its own built-in login/password-reset rate limit
	# (5/hour/IP, per its docs), but this is a supplementary Caddy-layer
	# zone scoped to just the authentication surface — same defense-in-depth
	# reasoning as every other app in this repo — not the day-to-day
	# authenticated admin API traffic (writing/editing posts), which stays
	# under the general zone above instead.
	rate_limit {
		zone rl_blog_auth {
			match {
				path /ghost/api/admin/session/* /ghost/api/admin/authentication/*
			}
			key {remote_host}
			events 15
			window 1m
		}
	}

	# Web analytics (Ghost's Stats page, backed by Tinybird) — the ghost-stats.js
	# script on public pages posts page-hit events here. Routed to
	# traffic-analytics (see ../blog/compose.yaml), NOT to Ghost itself —
	# pattern and path-stripping verbatim from Ghost's own reference Caddy
	# config (github.com/TryGhost/ghost-docker), just pointed at this
	# service's published Mac port instead of a co-located container name,
	# same adaptation as everything else in this Caddyfile.
	@analytics_paths path_regexp analytics_match ^(.*)/\.ghost/analytics(.*)$
	handle @analytics_paths {
		rewrite * {re.analytics_match.2}
		reverse_proxy http://{$MAC_IP}:3001
	}

	reverse_proxy http://{$MAC_IP}:2368
}

# ── ways-of-working.mathewcsims.uk (permanent redirect) ──────────────────
# Formerly its own standalone page; now folded into this blog as
# https://blog.mathewcsims.uk/ways-of-working/. `redir ... permanent` issues
# a 301, telling browsers/search engines the move is final so bookmarks and
# search results update rather than re-checking the old URL indefinitely.
# No app behind this at all — just a cert + redirect — so no rate-limit
# zone needed (nothing here to brute-force or abuse), but the shared
# security-headers snippet costs nothing to keep on.
ways-of-working.mathewcsims.uk {
	import security_headers
	redir https://blog.mathewcsims.uk/ways-of-working/ permanent
}

# ── Nimbus (running HERE on the Pi, not the Mac) ──────────────────────────
# Clean public URL https://dashboard.mathewcsims.uk. Unlike every other app,
# Nimbus is a separate docker-compose project also on the Pi (see ../nimbus/),
# for resilience if the Mac is down. It joins the `pi-shared` Docker network
# (created by this compose project — see compose.yaml) and is reached by
# container name, not an IP:port — no host port is published for it at all.
dashboard.mathewcsims.uk {
	import security_headers
	import general_ratelimit dashboard

	# Nimbus has NO brute-force/rate-limit protection anywhere in its own
	# codebase (confirmed by reading its source) — unlike copyparty's
	# --ban-pw/--ban-403 (on by default) and Vikunja's VIKUNJA_RATELIMIT_*.
	# This is the compensating control: an unauthenticated attacker gets 10
	# attempts/minute/IP against login/register/password-reset/OAuth-callback
	# before Caddy itself starts rejecting the requests — well below anything
	# a real user needs, and low enough to make online password-guessing
	# impractical against the shared admin login (see nimbus/compose.yaml —
	# there is no per-user login here, just the one admin account shared per
	# the earlier decision).
	rate_limit {
		zone rl_dashboard_auth {
			match {
				path /api/v1/auth/*
			}
			key {remote_host}
			events 10
			window 1m
		}
	}

	# Workaround for a bug in Nimbus itself: avatar uploads are written to
	# /uploads/avatars/<file> and that exact path (no /api/v1 prefix) is what
	# gets stored as avatar_url and returned to the frontend. But Nimbus's own
	# bundled nginx only routes /api/* to the Go backend that actually owns
	# /uploads/avatars/* and /uploads/service-icons/* — everything else falls
	# through to the Next.js frontend, which 404s on those paths. Rewriting
	# here fixes it for already-uploaded avatars too, not just future ones,
	# and survives Nimbus image updates since the fix lives in our Caddyfile,
	# not inside their container. See SETUP.md.
	@uploads path /uploads/*
	rewrite @uploads /api/v1{uri}

	# Second, deeper Nimbus bug: Next.js's built-in image optimizer
	# (/_next/image?url=...) does its OWN internal fetch of the source image
	# from Next's own process (port 3001 inside the container), never through
	# the nginx layer that bridges to the Go backend. Since /api/v1/uploads/*
	# only exists behind nginx+the Go backend, that internal fetch always gets
	# Next's own 404 HTML page back, which sharp then rejects as "not a valid
	# image" — every avatar/service-icon thumbnail fails to render, even
	# though the upload succeeded and the raw file is fully fetchable (proven
	# working by the @uploads rewrite above). This one can't be fixed by
	# proxying differently — the failing request never leaves the container,
	# so nothing outside it can intercept where it goes. Instead: catch the
	# outer /_next/image request before Next.js's optimizer gets it, and
	# rewrite straight to the raw (already-working) image path — scoped
	# narrowly to our known-safe upload prefix, not every /_next/image
	# request, so this can't be abused as an open internal-path redirector.
	#
	# Caddy's plain `query` matcher only supports exact-value or bare "*"
	# (any-value) matches — no substring/prefix globbing (confirmed from
	# Caddy's own matchers.go source) — so a CEL `expression` matcher is used
	# instead for the .startsWith() check. Caddy placeholders used inside an
	# expression must stay UNQUOTED: they get expanded into a proper CEL
	# function call (ph(req, "...")) before compilation, not substituted as
	# literal text — wrapping one in quotes turns it into an inert string
	# literal that can never match anything.
	@nextimage_uploads expression `path('/_next/image') && {http.request.uri.query.url}.startsWith('/api/v1/uploads/')`
	rewrite @nextimage_uploads {http.request.uri.query.url}

	reverse_proxy nimbus:3000
}

# ── Speedtest Tracker (running HERE on the Pi, LAN-ONLY) ─────────────────
# Clean public URL https://speedtest.mathewcsims.uk, but only for LAN clients
# — same pattern as mc37 below: a real public A-record lets Caddy obtain a
# Let's Encrypt cert (needed regardless of who's allowed to actually use the
# site), but only private/LAN source IPs get proxied through; everyone else
# gets a closed connection. Unlike mc37 this is a container on the Pi itself
# (see ../speedtest-tracker/), reached over `pi-shared` by container name —
# same no-published-port pattern as Nimbus. Deliberately not using
# speedtest-tracker's own ALLOWED_IPS env var for this: with no documented
# trusted-proxy/X-Forwarded-For config on that app, it would only ever see
# Caddy's own container IP as the "client", not real LAN clients — the
# request-source check has to happen here, at the actual network edge, not
# in the app.
#
# `100.64.0.0/10` alongside `private_ranges`: Tailscale assigns every
# device an IP in this CGNAT range, which Caddy's own `private_ranges`
# shortcut does NOT include (confirmed directly from Caddy's source,
# internal/ranges.go — it's just RFC1918 + loopback). Without this, a
# connection arriving via the tailnet (e.g. babel, this same Pi, acting as
# a Tailscale subnet router/exit node) would always be rejected here, even
# though it's exactly the kind of "trusted network" access this LAN-gate is
# meant to allow. This alone only helps once the connection actually
# *arrives* carrying a Tailscale-range source IP — see SETUP.md's Tailscale
# DNS section for the other half (making these hostnames resolve to
# 10.0.1.19 in the first place while tailnet-connected).
speedtest.mathewcsims.uk {
	import security_headers
	import general_ratelimit speedtest

	@lan remote_ip private_ranges 100.64.0.0/10 # + Tailscale CGNAT range
	handle @lan {
		reverse_proxy speedtest-tracker:80
	}
	# non-LAN (internet) clients: closed connection, nothing revealed
	handle {
		abort
	}
}

# ── Landing page (running on the Mac) ─────────────────────────────────────
# The bare apex domain, not a subdomain — everything else in this Caddyfile
# is a subdomain of mathewcsims.uk, covered by the existing wildcard DNS
# record; the apex itself needed its own explicit A record, added directly
# by the domain owner rather than through this repo. Genuinely static site
# (see ../landing-page/), so no rate-limit zone is really load-bearing here
# — nothing to brute-force or abuse — but it's cheap to keep on for
# consistency with every other site.
mathewcsims.uk {
	import security_headers
	import general_ratelimit landing
	reverse_proxy http://{$MAC_IP}:3080
}

# ── Karakeep (running on the Mac) ──────────────────────────────────────────
# Clean public URL https://karakeep.mathewcsims.uk. Migrated from a separate
# Tailscale-sidecar-only deployment — this Caddy block is now its only
# ingress. Same pattern as every other Mac app: Caddy terminates TLS and
# proxies to plain-HTTP Karakeep. Registration is closed
# (DISABLE_SIGNUPS=true in ../karakeep/compose.yaml) now that this is public.
karakeep.mathewcsims.uk {
	import security_headers
	import general_ratelimit karakeep

	# Karakeep's own RATE_LIMITING_ENABLED covers its API generally, but this
	# Caddy-layer zone specifically targets the NextAuth credentials-login
	# callback — same defense-in-depth reasoning as every other app's auth
	# endpoint in this repo.
	rate_limit {
		zone rl_karakeep_auth {
			match {
				path /api/auth/callback/credentials
			}
			key {remote_host}
			events 15
			window 1m
		}
	}

	reverse_proxy http://{$MAC_IP}:3000
}

# ── TimeTagger (running on the Mac) ────────────────────────────────────────
# Clean public URL https://time.mathewcsims.uk. Same pattern as every other
# Mac app: Caddy terminates TLS and proxies to a plain-HTTP backend on the
# Mac — but here that backend is oauth2-proxy, not TimeTagger itself.
# TimeTagger has no native OAuth (unlike ../nimbus/'s Infomaniak OIDC), so
# oauth2-proxy sits in front doing the actual Infomaniak login and only
# forwards requests it has verified on to TimeTagger, over a network Caddy
# can't reach at all — see ../timetagger/compose.yaml's file header for the
# full reasoning. Caddy's normal X-Forwarded-For/-Proto/-Host is all
# oauth2-proxy needs; nothing extra required here.
time.mathewcsims.uk {
	import security_headers
	import general_ratelimit time
	reverse_proxy http://{$MAC_IP}:4180
}

# ── Apprise (running HERE on the Pi, LAN-ONLY) ────────────────────────────
# Clean public URL https://apprise.mathewcsims.uk, but only for LAN clients —
# same pattern as Speedtest Tracker above: a real public A-record lets Caddy
# obtain a Let's Encrypt cert, but only private/LAN source IPs get proxied
# through. Apprise has NO built-in authentication at all (confirmed in its
# own README) — this LAN-gate is its only access control, since there's no
# in-app auth option to layer on top of instead. See ../apprise/compose.yaml.
apprise.mathewcsims.uk {
	import security_headers
	import general_ratelimit apprise

	@lan remote_ip private_ranges 100.64.0.0/10 # + Tailscale CGNAT range
	handle @lan {
		reverse_proxy apprise:8000
	}
	# non-LAN (internet) clients: closed connection, nothing revealed
	handle {
		abort
	}
}

# ── Uptime Kuma (running HERE on the Pi) ──────────────────────────────────
# Clean public URL https://status.mathewcsims.uk — a public status page plus
# a login-gated admin dashboard for monitoring every other hostname in this
# repo. Caddy's reverse_proxy automatically upgrades WebSocket connections
# (Kuma's live dashboard runs over Socket.IO) — nothing extra needed here for
# that. Only the general per-IP rate limit applies: Kuma's login is
# Socket.IO-based, not a REST path, so the usual path-matched Caddy auth zone
# (see every other app above) doesn't apply here — 2FA in Kuma's own Settings
# is the compensating control instead. See ../uptime-kuma/compose.yaml.
status.mathewcsims.uk {
	import security_headers
	import general_ratelimit status
	reverse_proxy uptime-kuma:3001
}

# ── Vikunja webhook relay (running HERE on the Pi, LAN-ONLY) ─────────────
# Clean public URL https://vikunja-relay.mathewcsims.uk, but only for LAN
# clients — same pattern as Apprise/Speedtest Tracker above. Bridges
# Vikunja's webhook payload shape to Apprise's /notify shape (see
# ../vikunja-webhook-relay/compose.yaml for why this exists at all — the two
# don't line up without something in between). The real access control is
# HMAC-SHA256 verification inside the relay itself (X-Vikunja-Signature),
# not this LAN-gate — but every other machine-to-machine app in this repo
# gets one anyway, so this does too, for consistency and defense in depth.
vikunja-relay.mathewcsims.uk {
	import security_headers
	import general_ratelimit vikunja_relay

	@lan remote_ip private_ranges 100.64.0.0/10 # + Tailscale CGNAT range
	handle @lan {
		reverse_proxy vikunja-webhook-relay:8080
	}
	# non-LAN (internet) clients: closed connection, nothing revealed
	handle {
		abort
	}
}

# ── Kopia backup server (running HERE on the Pi, LAN-ONLY) ───────────────
# Clean public URL https://backup.mathewcsims.uk, but only for LAN clients —
# same pattern as Apprise/Speedtest Tracker above, and for the same reason
# as every other admin surface in this repo: this can browse AND restore
# (and, if compromised, delete) every backup this stack has, so it never
# gets anywhere near the internet even with a login in front of it.
#
# Unlike every other backend in this Caddyfile, Kopia's server is HTTPS
# with a self-signed cert (its own web UI needs TLS to work correctly, and
# Kopia's own reverse-proxy docs recommend real TLS on the backend rather
# than its `--insecure` mode, which is a hidden/dev-only flag in Kopia's
# own source — not something to rely on in production). Caddy still
# terminates the real public-facing TLS; this is just the internal hop to
# a self-signed cert over the trusted `pi-shared` network, same reasoning
# as the mc37 router-admin block below.
backup.mathewcsims.uk {
	import security_headers
	import general_ratelimit backup

	@lan remote_ip private_ranges 100.64.0.0/10 # + Tailscale CGNAT range
	handle @lan {
		reverse_proxy https://kopia-server:51515 {
			transport http {
				tls_insecure_skip_verify # Kopia's own self-signed cert
			}
		}
	}
	# non-LAN (internet) clients: closed connection, nothing revealed
	handle {
		abort
	}
}

# ── DrayTek router admin (LAN-ONLY) ──────────────────────────────────────
# Values hardcoded on purpose: they're fixed, and an empty env var here would
# produce a keyless "{ }" block that crashes Caddy on startup.
# A PUBLIC A-record (mc37 → WAN IP) lets Caddy obtain a Let's Encrypt cert, but
# only private/LAN source IPs are allowed through — internet clients are
# dropped, so the router admin is never actually exposed. Pair with a DrayTek
# "LAN DNS" entry (mc37.mathewcsims.uk → 10.0.1.19) so LAN devices reach the Pi
# directly and their source IP is private (passing the check below).
mc37.mathewcsims.uk {
	@lan remote_ip private_ranges 100.64.0.0/10 # + Tailscale CGNAT range
	handle @lan {
		reverse_proxy https://10.0.1.1:8443 {
			transport http {
				tls_insecure_skip_verify # router uses a self-signed cert
			}
		}
	}
	# non-LAN (internet) clients: closed connection, nothing revealed
	handle {
		abort
	}
}

# ── Refuse every other hostname / bare-IP access ─────────────────────────
# Only the hostnames explicitly configured above are served. Any other
# SNI/Host — including a bare-IP scan of the public address — gets a closed
# connection, revealing nothing.
:80 {
	abort
}

:443 {
	tls internal
	abort
}
