<plist version="1.0">
<dict>
    <key>Label</key>
    <string>uk.mathewcsims.trivy-scan</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/mathewcsims/self-hosted/trivy-scan/scan.py</string>
    </array>
    <key>StartCalendarInterval</key>
