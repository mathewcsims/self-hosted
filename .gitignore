# ── Secrets ──────────────────────────────────────────────────────────────
# Every real .env and accounts.conf holds live credentials. Only their
# .example templates are ever tracked.
.env
**/.env
copyparty/cfg/accounts.conf

# ── Runtime data & databases ────────────────────────────────────────────
# This repo is infrastructure-as-code only — never the actual files,
# notes, sessions, or databases the apps generate while running.
copyparty/data/
copyparty/public/
copyparty/inbox/
# copyparty's own internal state: salts, sessions.db, shares.db, cert.pem, iphash
copyparty/cfg/copyparty/
memos-prospect-ukri-tus/data/
vikunja/db/
vikunja/files/
nimbus/db/
nimbus/uploads/
pi-reverse-proxy/caddy_data/
pi-reverse-proxy/caddy_config/
speedtest-tracker/config/
blog/db/
blog/content/
blog/traffic-analytics-data/
karakeep/data/
karakeep/meilisearch-data/
karakeep/meilisearch-data-old-1.11.1/
apprise/config/
uptime-kuma/data/
kopia-server/config/
kopia-server/cache/
kopia-server/logs/
kopia-server/tmp/
timetagger/data/
timetagger/oauth2-proxy/authenticated-emails.txt
pi-reverse-proxy/logs/
owl/data/
marque/data/
bookstack/db/
bookstack/config/
forgejo/data/

# ── Tool-local / editor state ───────────────────────────────────────────
# Claude Code's own local session cache — unrelated to this project, and
# has been seen to cache credentials from earlier terminal commands.
# Exception: .claude/skills/ holds deliberately-authored, versioned tooling
# (e.g. the BookStack API skill) that should travel with the repo, not
# ephemeral session state — `.claude/*` (not `.claude/`) so the negation
# below can actually re-include it (git can't un-ignore a path whose parent
# directory is itself excluded).
.claude/*
!.claude/skills/

# ── Logs ─────────────────────────────────────────────────────────────────
autostart/*.log
*.log

# ── OS cruft ─────────────────────────────────────────────────────────────
.DS_Store
