# Template only — the real .env is fetched live from Proton Pass at deploy
# time via scripts/pass-deploy-remote.sh, never committed here. See
# scripts/pass-create-vikunja-relay-secret.sh to generate this value and
# store it in the "VikunjaWebhookRelay" Pass item.
#
#   ./scripts/pass-create-vikunja-relay-secret.sh

# Must exactly match the "Secret" field entered in Vikunja's Settings ->
# Webhook Notifications for this webhook.
WEBHOOK_SECRET=changeme
