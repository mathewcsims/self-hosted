# These fields live as a Proton Pass item ("SpeedtestTracker", in the Agent
# Secrets vault) now, not a real .env file — see ../SETUP.md's "Secrets
# management" section. Deployed via ./scripts/pass-deploy-remote.sh, which
# fetches these and pipes them over SSH to the Pi. This file just
# documents which fields that item needs.

# Laravel encryption key. Generate with:
#   echo "base64:$(openssl rand -base64 32)"
# Paste the FULL output including the "base64:" prefix.
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_OPENSSL

# Strong password for the initial admin account (mat@mathewcsims.uk — set in
# compose.yaml). Generate with: openssl rand -base64 24 | tr -d '=+/' | cut -c1-24
ADMIN_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD
