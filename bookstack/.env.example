# These fields live as a Proton Pass item ("BookStack", in the Self-Hosted
# Secrets vault) now, not a real .env file — see ../SETUP.md's "Secrets
# management" section. This file just documents which fields that item
# needs. Created via ../scripts/pass-create-bookstack-secrets.sh.

# Laravel session/cookie encryption key, "base64:" + 32 random bytes.
APP_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# MariaDB. Alphanumeric-only deliberately — non-alphanumeric characters in
# DB_PASSWORD need careful escaping through compose's ${VAR} interpolation.
DB_ROOT_PASSWORD=CHANGE_ME_GENERATE_ALPHANUMERIC
DB_PASSWORD=CHANGE_ME_GENERATE_ALPHANUMERIC
